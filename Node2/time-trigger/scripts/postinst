#!/bin/bash
# SPDX-FileCopyrightText: Copyright 2026 LG Electronics Inc.
# SPDX-License-Identifier: MIT
#
# Timpani-N Post-Installation Script
# This script runs after package installation (DEB/RPM)
#

set -e

BINARY_PATH="/usr/bin/timpani-n"
SCRIPT_PATH="/usr/share/timpani-n"

# Colors
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
RED='\033[0;31m'
NC='\033[0m'

echo "=========================================="
echo "  Timpani-N Post-Installation Setup"
echo "=========================================="
echo ""

# 1. Set capabilities on the binary
echo "Setting capabilities on $BINARY_PATH..."
if command -v setcap &>/dev/null && [ -f "$BINARY_PATH" ]; then
    if setcap cap_bpf,cap_perfmon,cap_sys_nice,cap_sys_ptrace+ep "$BINARY_PATH" 2>/dev/null; then
        echo -e "${GREEN}✓ Capabilities set successfully${NC}"
        echo "  timpani-n can now run without root privileges"
    else
        echo -e "${YELLOW}⚠ Failed to set capabilities${NC}"
        echo "  timpani-n will require root privileges (sudo)"
    fi
else
    echo -e "${YELLOW}⚠ setcap not available or binary not found${NC}"
    echo "  timpani-n will require root privileges (sudo)"
fi
echo ""

# 2. Check kernel version
KERNEL_VERSION=$(uname -r)
MAJOR=$(echo "$KERNEL_VERSION" | cut -d. -f1)
MINOR=$(echo "$KERNEL_VERSION" | cut -d. -f2)
VERSION_NUM=$((MAJOR * 100 + MINOR))

echo "Checking kernel version..."
if [ $VERSION_NUM -lt 515 ]; then
    echo -e "${RED}✗ Kernel $KERNEL_VERSION is not supported${NC}"
    echo "  Timpani-N requires kernel 5.15 or newer"
    echo "  Please upgrade your kernel before using timpani-n"
elif [ $VERSION_NUM -lt 606 ]; then
    echo -e "${YELLOW}⚠ Kernel $KERNEL_VERSION is supported but not optimal${NC}"
    echo "  Recommend upgrading to 6.6+ for better eBPF stability"
else
    echo -e "${GREEN}✓ Kernel $KERNEL_VERSION is supported${NC}"
fi
echo ""

# 3. Check BTF support
echo "Checking BTF support..."
if [ -f /sys/kernel/btf/vmlinux ]; then
    echo -e "${GREEN}✓ BTF support available${NC}"
else
    echo -e "${RED}✗ BTF not available${NC}"
    echo "  Your kernel needs CONFIG_DEBUG_INFO_BTF=y"
    echo "  eBPF features will NOT work without BTF"
fi
echo ""

# 4. Check RT kernel (informational)
if uname -r | grep -qi "rt\|preempt"; then
    echo "RT kernel detected..."
    if [ $VERSION_NUM -lt 612 ]; then
        echo -e "${YELLOW}⚠ RT kernel < 6.12 detected${NC}"
        echo "  eBPF ring buffer may cause issues on RT kernels < 6.12"
        echo "  Consider upgrading to 6.12+ for production RT workloads"
    else
        echo -e "${GREEN}✓ RT kernel 6.12+ detected (optimal)${NC}"
    fi
    echo ""
fi

# 5. Mount BPF filesystem if not mounted
echo "Checking BPF filesystem..."
if mount | grep -q "bpf on /sys/fs/bpf"; then
    echo -e "${GREEN}✓ BPF filesystem already mounted${NC}"
else
    echo "BPF filesystem not mounted, attempting to mount..."
    if mount -t bpf bpf /sys/fs/bpf 2>/dev/null; then
        echo -e "${GREEN}✓ BPF filesystem mounted${NC}"
    else
        echo -e "${YELLOW}⚠ Could not mount BPF filesystem${NC}"
        echo "  Run manually: sudo mount -t bpf bpf /sys/fs/bpf"
    fi
fi
echo ""

# 6. Print usage information
echo "=========================================="
echo "  Installation Complete"
echo "=========================================="
echo ""
echo "To verify your system:"
echo "  $SCRIPT_PATH/check-requirements.sh"
echo ""
echo "To run timpani-n:"
echo "  timpani-n              # With capabilities"
echo "  sudo timpani-n         # As root"
echo ""
echo "Documentation:"
echo "  /usr/share/doc/timpani-n/"
echo ""

exit 0
